{
  "name": "briefs-todo-app-starter",
  "version": "0.1.0",
  "description": "To-Do application with FastAPI, SvelteKit, and Tailwind CSS v4",
  "type": "module",
  "author": "Maxime Lenne",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.11.0"
  },
  "packageManager": "bun@1.1.45",
  "scripts": {
    "lint": "bun run lint:md && bun run lint:yaml && bun run lint:js && bun run lint:docker",
    "lint:js": "eslint . --ext .js,.ts,.svelte",
    "lint:js:fix": "eslint . --ext .js,.ts,.svelte --fix",
    "lint:format": "prettier --check .",
    "lint:format:fix": "prettier --write .",
    "lint:md": "markdownlint-cli2 **/*.md",
    "lint:md:fix": "markdownlint-cli2 --fix **/*.md",
    "lint:yaml": "yamllint .",
    "lint:docker": "hadolint < api/Dockerfile < web/Dockerfile",
    "format": "prettier --write \"**/*.{js,ts,svelte,json,yml,yaml,md}\"",
    "commit": "gitmoji -c",
    "changelog": "standard-version",
    "changelog:init": "standard-version --first-release",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-gitmoji": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-svelte": "^2.0.0",
    "gitmoji-cli": "^9.0.0",
    "hadolint": "^14.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "markdownlint-cli2": "^0.12.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "semantic-release": "^24.0.0",
    "standard-version": "^9.5.0",
    "svelte-eslint-parser": "^0.30.0",
    "yamllint": "^0.3.1"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ],
    "*.{md,markdown}": [
      "markdownlint-cli2 --fix"
    ],
    "*.{yml,yaml}": [
      "yamllint"
    ],
    "Dockerfile*": [
      "hadolint"
    ],
    "*.py": [
      "ruff check --fix",
      "mypy"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/gitmoji-cli"
    }
  }
}
